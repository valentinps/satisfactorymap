# Credentials / runtime state
sftp_config.json
sftp_config.json.example
server_config.json

# Downloaded saves and uploads (runtime directories)
sftp_saves/
map/uploads/

# Large local-only assets (not versioned)
map_highres.png
blank_map20.png

# Parser output
map_output/

# Satisfactory save files
*.sav

# Python cache
__pycache__/
*.pyc
*.pyo

# Game data dump (copy from your game install's
# Satisfactory\CommunityResources\Docs\en-US.json) and the JSON generated
# from it via docs/extract_docs_json.py; see README.md's "Generating game
# data" section. docs/generated/SCHEMA.md itself is hand-written, not
# generated, and stays tracked.
Docs.json
docs/generated/*.json

# Icon PNGs (regenerate via docs/copy_icons.py; see README.md's
# "Generating icons" section).
map/static/map/icons/

.claude