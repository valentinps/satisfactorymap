{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Satisfactory Save Map",
  "version": "0.1.6",
  "identifier": "com.satisfactorymap.desktop",
  "build": {
    "frontendDist": "../../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Satisfactory Save Map",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self'; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNFNjAyRjg3N0M3OTdCM0MKUldROGUzbDhoeTlnUHJqN202VnYrd3R1OGZJVWE3c0xMdVdZbGRSQlEwY3MxYmJsZGpQT0F2Q2QK",
      "endpoints": [
        "https://github.com/valentinps/satisfactorymap/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
